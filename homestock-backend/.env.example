# Copy to .env and adjust for your NAS.
POSTGRES_USER=homestock
POSTGRES_PASSWORD=changeme
POSTGRES_DB=homestock

# Port exposed on the NAS LAN (the Android app connects here).
API_PORT=8080

# Minimum cosine similarity for a semantic search match (0.0–1.0).
# Lower = more (noisier) results, higher = stricter. Default 0.4.
# SEMANTIC_THRESHOLD=0.4
