# Copy to .env and adjust for your NAS.
POSTGRES_USER=homestock
POSTGRES_PASSWORD=changeme
POSTGRES_DB=homestock

# Port exposed on the NAS LAN (the Android app connects here).
API_PORT=8080

# Minimum cosine similarity for a semantic search match (0.0–1.0).
# Lower = more (noisier) results, higher = stricter. Default 0.25
# (multilingual-MiniLM produces normalized vectors; 0.25 is lenient
# enough to tolerate typos while still filtering unrelated objects).
# SEMANTIC_THRESHOLD=0.25

# Wine enrichment via a local Ollama LLM (no API key, no internet calls).
# The homestock-ollama container is started by docker-compose; on first
# boot it auto-pulls the model below into a persistent volume.
#
# To disable enrichment entirely (e.g. to free 2 GB of RAM on a small NAS):
# set OLLAMA_BASE_URL to an empty value. The endpoint then returns 503 and
# the wine fiche surfaces a friendly error — everything else keeps working.
#
# Default model is light (~2 GB on disk, ~2 GB RAM during inference).
# Swap to "mistral:7b-instruct" for noticeably better French sommelier
# output if your NAS has the headroom (~5 GB).
OLLAMA_BASE_URL=http://homestock-ollama:11434
OLLAMA_MODEL=llama3.2:3b
